# file_manager.py
"""
文件系统管理器 - 提供文件和目录管理功能
"""

import time
import pickle
from typing import Dict, List, Optional


# ==================== 异常定义 ====================
class FileSystemError(Exception):
    pass

class FileNotFoundError(FileSystemError):
    pass

class FileExistsError(FileSystemError):
    pass

class NotADirectoryError(FileSystemError):
    pass

class IsADirectoryError(FileSystemError):
    pass

class DirectoryNotEmptyError(FileSystemError):
    pass


# ==================== 数据模型 ====================
class Entry:
    """文件系统条目基类"""
    def __init__(self, name: str, parent=None):
        self.name = name
        self.parent = parent
        self.created = time.time()
        self.modified = time.time()
    
    def get_path(self) -> str:
        if self.parent is None:
            return '/'
        parts = []
        cur = self
        while cur.parent:
            parts.append(cur.name)
            cur = cur.parent
        return '/' + '/'.join(reversed(parts))
    
    def is_file(self) -> bool:
        return isinstance(self, File)
    
    def is_dir(self) -> bool:
        return isinstance(self, Directory)


class File(Entry):
    """普通文件"""
    def __init__(self, name: str, parent=None, content: str = ''):
        super().__init__(name, parent)
        self._content = content
    
    def read(self) -> str:
        self.modified = time.time()
        return self._content
    
    def write(self, content: str, append: bool = False):
        if append:
            self._content += content
        else:
            self._content = content
        self.modified = time.time()
    
    @property
    def size(self) -> int:
        return len(self._content)


class Directory(Entry):
    """目录"""
    def __init__(self, name: str, parent=None):
        super().__init__(name, parent)
        self._entries: Dict[str, Entry] = {}
    
    def add(self, entry: Entry):
        if entry.name in self._entries:
            raise FileExistsError(f"'{entry.name}' already exists")
        self._entries[entry.name] = entry
        entry.parent = self
    
    def remove(self, name: str):
        if name not in self._entries:
            raise FileNotFoundError(f"'{name}' not found")
        del self._entries[name]
    
    def get(self, name: str) -> Optional[Entry]:
        return self._entries.get(name)
    
    def list(self) -> List[str]:
        return list(self._entries.keys())
    
    def is_empty(self) -> bool:
        return len(self._entries) == 0


# ==================== 路径解析器 ====================
class PathResolver:
    """路径解析器"""
    def __init__(self, root: Directory, cwd: Directory):
        self.root = root
        self.cwd = cwd
    
    def resolve(self, path: str) -> Entry:
        if not path:
            raise FileSystemError("Empty path")
        
        if path.startswith('/'):
            current = self.root
            parts = [p for p in path.split('/') if p]
        else:
            current = self.cwd
            parts = [p for p in path.split('/') if p]
        
        for part in parts:
            if part == '.':
                continue
            if part == '..':
                if current.parent:
                    current = current.parent
                continue
            
            if not current.is_dir():
                raise NotADirectoryError(f"'{current.get_path()}' is not a directory")
            
            entry = current.get(part)
            if entry is None:
                raise FileNotFoundError(f"路径组件 '{part}' 未找到")
            current = entry
        
        return current
    
    def resolve_parent(self, path: str):
        if path == '/':
            raise FileSystemError("Cannot operate on root directory's parent")
        
        path = path.rstrip('/')
        if not path:
            raise FileSystemError("Invalid path")
        
        if '/' not in path:
            parent = self.cwd
            last = path
        else:
            parent_path = path[:path.rfind('/')]
            last = path[path.rfind('/')+1:]
            if not parent_path:
                parent_path = '/'
            parent = self.resolve(parent_path)
        
        if not parent.is_dir():
            raise NotADirectoryError(f"父路径不是目录")
        return parent, last


# ==================== 文件管理器主类 ====================
class FileManager:
    def __init__(self):
        self.root = Directory('')
        self.root.parent = None
        self.cwd = self.root
        self._resolver = PathResolver(self.root, self.cwd)
        print("文件系统初始化完成")
    
    def _update_resolver(self):
        self._resolver.cwd = self.cwd

    # ==================== 目录操作 ====================
    def mkdir(self, path: str):
        try:
            self._update_resolver()
            parent, name = self._resolver.resolve_parent(path)
            if parent.get(name):
                raise FileExistsError(f"目录已存在")
            new_dir = Directory(name, parent)
            parent.add(new_dir)
            print(f"目录创建成功: {new_dir.get_path()}")
        except FileSystemError as e:
            print(f"创建目录失败: {e}")

    def rmdir(self, path: str):
        try:
            self._update_resolver()
            target = self._resolver.resolve(path)
            if not target.is_dir():
                raise NotADirectoryError("不是目录")
            if not target.is_empty():
                raise DirectoryNotEmptyError("目录非空，无法删除")
            if target.parent is None:
                raise FileSystemError("无法删除根目录")
            target.parent.remove(target.name)
            print(f"目录删除成功: {path}")
        except FileSystemError as e:
            print(f"删除目录失败: {e}")

    def ls(self, path: str = '.') -> List[str]:
        try:
            self._update_resolver()
            target = self._resolver.resolve(path)
            if not target.is_dir():
                raise NotADirectoryError("不是目录")
            return target.list()
        except FileSystemError as e:
            print(f"列出目录失败: {e}")
            return []

    def show_dir(self, path: str = '.'):
        try:
            entries = self.ls(path)
            if not entries:
                print("  (空目录)")
                return
            base_path = self._resolver.resolve(path).get_path()
            for name in sorted(entries):
                entry_path = f"{base_path}/{name}" if base_path != '/' else f"/{name}"
                entry = self._resolver.resolve(entry_path)
                if entry.is_dir():
                    print(f"{name}/")
                else:
                    print(f"{name} ({entry.size} 字节)")
        except Exception as e:
            print(f"显示目录内容失败: {e}")

    # ==================== 文件操作 ====================
    def touch(self, path: str, content: str = ''):
        try:
            self._update_resolver()
            parent, name = self._resolver.resolve_parent(path)
            existing = parent.get(name)
            if existing:
                if existing.is_file():
                    existing.modified = time.time()
                    print(f"文件已存在，更新时间戳")
                    return
                raise FileExistsError("同名目录已存在")
            new_file = File(name, parent, content)
            parent.add(new_file)
            print(f"文件创建成功: {new_file.get_path()}")
        except FileSystemError as e:
            print(f"创建文件失败: {e}")

    def create(self, path: str, content: str = ''):
        try:
            self._update_resolver()
            parent, name = self._resolver.resolve_parent(path)
            existing = parent.get(name)
            if existing:
                if existing.is_dir():
                    raise IsADirectoryError("是目录，无法覆盖")
                parent.remove(name)
            new_file = File(name, parent, content)
            parent.add(new_file)
            print(f"文件创建/覆盖成功")
        except FileSystemError as e:
            print(f"创建文件失败: {e}")

    def read(self, path: str) -> str:
        try:
            self._update_resolver()
            target = self._resolver.resolve(path)
            if not target.is_file():
                raise IsADirectoryError("是目录，无法读取")
            return target.read()
        except FileSystemError as e:
            print(f"读取文件失败: {e}")
            return ""

    def write(self, path: str, content: str, append: bool = False):
        try:
            self._update_resolver()
            try:
                target = self._resolver.resolve(path)
            except FileNotFoundError:
                parent, name = self._resolver.resolve_parent(path)
                new_file = File(name, parent)
                parent.add(new_file)
                target = new_file

            if not target.is_file():
                raise IsADirectoryError("是目录，无法写入")
            target.write(content, append)
            print(f"写入成功: {path}")
        except FileSystemError as e:
            print(f"写入失败: {e}")

    def delete(self, path: str):
        try:
            self._update_resolver()
            target = self._resolver.resolve(path)
            if target.is_dir():
                raise IsADirectoryError("是目录，请用 rmdir")
            if target.parent is None:
                raise FileSystemError("无法删除根目录")
            target.parent.remove(target.name)
            print(f"文件删除成功: {path}")
        except FileSystemError as e:
            print(f"删除失败: {e}")

    # ==================== 路径操作 ====================
    def cd(self, path: str):
        try:
            self._update_resolver()
            target = self._resolver.resolve(path)
            if not target.is_dir():
                raise NotADirectoryError("不是目录")
            self.cwd = target
            self._update_resolver()
            print(f"当前目录: {self.cwd.get_path()}")
        except FileSystemError as e:
            print(f"切换目录失败: {e}")

    def pwd(self) -> str:
        return self.cwd.get_path()

    def exists(self, path: str) -> bool:
        try:
            self._update_resolver()
            self._resolver.resolve(path)
            return True
        except:
            return False

    # ==================== 信息查询 ====================
    def get_info(self, path: str) -> dict:
        try:
            self._update_resolver()
            target = self._resolver.resolve(path)
            return {
                'name': target.name,
                'path': target.get_path(),
                'type': 'file' if target.is_file() else 'directory',
                'size': target.size if target.is_file() else len(target.list()),
                'created': target.created,
                'modified': target.modified,
            }
        except:
            return {}

    def show_info(self, path: str):
        info = self.get_info(path)
        if not info:
            print("获取信息失败")
            return
        print("-" * 30)
        print(f"名称: {info['name']}")
        print(f"路径: {info['path']}")
        print(f"类型: {info['type']}")
        print(f"大小: {info['size']}")
        print("-" * 30)

    # ==================== 持久化 ====================
    def save(self, filename: str = "fs_state.dat"):
        try:
            with open(filename, 'wb') as f:
                serialized_data = self._serialize()
                pickle.dump(serialized_data, f)
            # 打印调试信息：确认保存的根目录条目
            print(f"保存成功，根目录条目: {list(self.root._entries.keys())}")
        except Exception as e:
            # 显式打印具体错误类型和信息
            print(f"保存失败: {type(e).__name__}: {str(e)}")


    def load(self, filename: str = "fs_state.dat"):
        try:
            with open(filename, 'rb') as f:
                data = pickle.load(f)
            self._deserialize(data)
            self._update_resolver()
            self._resolver = PathResolver(self.root, self.cwd)
            # 打印调试信息：确认加载后的根目录条目
            print(f"加载成功，根目录条目: {list(self.root._entries.keys())}")
        except Exception as e:
            print(f"加载失败: {type(e).__name__}: {str(e)}")



    # 序列化（保存）：只存文件结构，不存当前目录
    def _serialize(self):
        def ser(entry):
            if entry.is_file():
                return {'t':'f','n':entry.name,'c':entry._content,'cr':entry.created,'mo':entry.modified}
            d = {'t':'d','n':entry.name,'cr':entry.created,'mo':entry.modified,'c':{}}
            for k,v in entry._entries.items():
                d['c'][k] = ser(v)
            return d
        return {'root': ser(self.root)}

    # 反序列化（加载）
    def _deserialize(self, data):
        def deser(d, p=None):
            if d['t'] == 'f':
                # 反序列化文件
                file_entry = File(d['n'], p, d['c'])
                file_entry.created = d['cr']
                file_entry.modified = d['mo']
                return file_entry
            # 反序列化目录
            dir_entry = Directory(d['n'], p)
            dir_entry.created = d['cr']
            dir_entry.modified = d['mo']
            # 递归恢复子条目
            for entry_name, entry_data in d['c'].items():
                child_entry = deser(entry_data, dir_entry)
                dir_entry._entries[entry_name] = child_entry
            return dir_entry

        # 恢复根目录并重置当前目录
        self.root = deser(data['root'])
        self.root.parent = None
        self.cwd = self.root


